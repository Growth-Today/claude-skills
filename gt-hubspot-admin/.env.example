# Copy this file to a `.env` inside the playbook folder you are running,
# e.g. playbooks/suppress-hard-bounced/.env
# Scripts read HUBSPOT_ACCESS_TOKEN via python-dotenv (load_dotenv on ../.env).

# HubSpot private app access token (Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional, used by specific playbooks:
# HUBSPOT_TARGET_OWNER_ID=
# HUBSPOT_TIMEZONE=UTC
